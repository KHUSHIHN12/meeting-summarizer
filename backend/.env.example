# Application
APP_NAME=AI Meeting Summarizer
APP_VERSION=1.0.0
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

# MongoDB Atlas (URL-encode special characters in credentials)
MONGODB_URI=mongodb+srv://khushi:<db_password>@cluster0.ke7yxmp.mongodb.net/?appName=Cluster0
MONGODB_DATABASE=meeting_summarizer
MONGODB_MIN_POOL_SIZE=1
MONGODB_MAX_POOL_SIZE=20
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

# Uploads
UPLOAD_DIRECTORY=../data/uploads
MAX_UPLOAD_SIZE_BYTES=104857600

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
